{"doc":{"body":"<!doctype html><div class=\"lake-content\" typography=\"classic\"><pre data-language=\"html\" id=\"PNu84\" class=\"ne-codeblock\">npm i tinymce</pre><p id=\"ud00245a3\" class=\"ne-p\"><span class=\"ne-text\">简单粗暴的方式：</span></p><ol class=\"ne-ol\"><li id=\"ua813a46a\"><span class=\"ne-text\">下载文件 放到public中</span><a href=\"https://www.yuque.com/attachments/yuque/0/2021/zip/200222/1624419753892-257d1db6-9f0c-4e9f-850e-4676d4f5303b.zip\" id=\"uff7bf008\" class=\"ne-card-file\">📎tinymce_5.8.1.zip</a><span class=\"ne-text\"> 并在index.html中引用 tinymce.min.js </span></li></ol><p id=\"uca3adacf\" class=\"ne-p\" style=\"text-indent: 2em\"><span class=\"ne-text\">中文化需要下载 </span><a href=\"https://www.yuque.com/attachments/yuque/0/2021/js/200222/1624420342999-f6ee3ad3-7d69-4ac5-9801-feb85ebc221f.js\" id=\"u32411494\" class=\"ne-card-file\">📎zh_CN.js</a></p><ol start=\"2\" class=\"ne-ol\"><li id=\"ubc9ac604\"><span class=\"ne-text\">写成组件</span></li></ol><pre data-language=\"vue\" id=\"LmQP5\" class=\"ne-codeblock\">&lt;template&gt;\n  &lt;div&gt;\n    &lt;textarea :id=&quot;id&quot; :value=&quot;value&quot;&gt;&lt;/textarea&gt;\n  &lt;/div&gt;\n&lt;/template&gt;\n\n&lt;script&gt;\nimport { mapActions, mapGetters } from 'vuex'\nimport 'xx/zh_CN.js' // 引入中文\n\nconst INIT = 0\nexport default {\n  name: 'TinymceEditor',\n  props: {\n    value: {\n      type: String,\n      required: true\n    },\n    setting: {}\n  },\n  data() {\n    return {\n      status: INIT,\n      id: 'editor-' + new Date().getMilliseconds(),\n      EDITOR: null\n    }\n  },\n  computed: {\n    ...mapGetters({\n      uploadImg: 'uploadImg', // 自定义图片上传\n    })\n  },\n  mounted() {\n    const setting = {\n      selector: '#' + this.id,\n      menubar: false,\n      language: 'zh_CN',\n      toolbar:\n        'formatselect bold italic underline strikethrough | fontselect fontsizeselect forecolor backcolor | alignleft aligncenter alignright alignjustify | bullist numlist | image table | link unlink | indent outdent | superscript subscript | removeformat |  wordcount charmap | undo redo | fullscreen | ',\n      plugins: [\n        'link',\n        'image',\n        'imagetools',\n        'table',\n        'lists',\n        'fullscreen',\n        'quickbars',\n        'charmap',\n        'autolink',\n        'wordcount'\n      ],\n      fontsize_formats: '12px 14px 16px 18px 24px 36px 48px 56px 72px',\n      font_formats:\n        '微软雅黑=Microsoft YaHei,Helvetica Neue,PingFang SC,sans-serif;苹果苹方=PingFang SC,Microsoft YaHei,sans-serif;宋体=simsun,serif;仿宋体=FangSong,serif;黑体=SimHei,sans-serif;Arial=arial,helvetica,sans-serif;Arial Black=arial black,avant garde;Book Antiqua=book antiqua,palatino;', //字体样式\n\n      height: '500px',\n      a11y_advanced_options: true,\n      branding: false, //隐藏右下角技术支持\n      paste_retain_style_properties: 'all',\n      paste_data_images: true,\n      image_advtab: true, //为图像属性编辑窗口添加高级属性，可以自定义图片的css样式（内置style）、边距（margin）和边框（border）。\n      image_description: false, //显示隐藏图片说明input\n      images_upload_handler: this.imgUpload,\n      imagetools_cors_hosts: [\n        'testimg.zuoyebang.cc',\n        'img.zuoyebang.cc',\n        'wiki.zuoyebang.cc'\n      ],\n      init_instance_callback: this.myCustomInitInstance,\n      quickbars_insert_toolbar: false,\n      quickbars_selection_toolbar: false,\n      placeholder: '请输入正文'\n    }\n    Object.assign(setting, this.setting)\n    tinymce.init(setting)\n  },\n  beforeDestroy: function () {\n    tinymce.get(this.id).destroy()\n  },\n  methods: {\n    ...mapActions({\n      uploading: 'uploadImgAction'\n    }),\n    myCustomInitInstance(editor) {\n      this.EDITOR = editor\n      editor.setContent(this.value)\n      editor.on('change input', () =&gt; {\n        var content = editor.getContent()\n        this.$route.query.docId\n          ? this.$emit('input', content)\n          : this.$emit('change', content)\n      })\n    },\n    async imgUpload(blobInfo, success, failure) {\n      //文件上传的formData传递\n      let formData = new FormData()\n      formData.append('file', blobInfo.blob(), blobInfo.filename())\n      await this.uploading(formData)\n      this.uploadImg.picUrl\n        ? success(this.uploadImg.picUrl)\n        : failure('上传失败')\n    }\n  }\n}\n&lt;/script&gt;\n</pre><p id=\"udf9d8a84\" class=\"ne-p\"><span class=\"ne-text\">3.父组件</span></p><pre data-language=\"vue\" id=\"vGbYx\" class=\"ne-codeblock\">&lt;el-form-item prop=&quot;content&quot;&gt;\n\t\t&lt;tiny-editor-page\n\t\t\t\tclass=&quot;editor&quot;\n        :value=&quot;form.content&quot;\n        @change=&quot;contentUe&quot;\n    &gt;&lt;/tiny-editor-page&gt;\n&lt;/el-form-item&gt;\n\n&lt;script&gt;\n  \n...\n\nmethods:{\n\t\tcontentUe(value) {\n      this.form.content = value //富文本中的内容\n    },\n}\n...\n&lt;/script&gt;</pre><p id=\"u5414d40d\" class=\"ne-p\"><span class=\"ne-text\" style=\"color: #ce9178; background-color: #1e1e1e; font-size: 16px\"></span></p><p id=\"u02006b3b\" class=\"ne-p\"><br></p></div>","body_asl":"<!doctype lake><meta name=\"doc-version\" content=\"1\" /><meta name=\"typography\" content=\"classic\" /><meta name=\"viewport\" content=\"fixed\" /><card type=\"inline\" name=\"codeblock\" value=\"data:%7B%22mode%22%3A%22html%22%2C%22code%22%3A%22npm%20i%20tinymce%22%2C%22autoWrap%22%3Atrue%2C%22theme%22%3A%22default%22%2C%22__spacing%22%3A%22both%22%2C%22heightLimit%22%3Atrue%2C%22id%22%3A%22PNu84%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D\"></card><p data-lake-id=\"ud00245a3\" id=\"ud00245a3\"><span data-lake-id=\"u77e94a53\" id=\"u77e94a53\">简单粗暴的方式：</span></p><ol list=\"u5fef75e7\"><li fid=\"u130289d0\" data-lake-id=\"ua813a46a\" id=\"ua813a46a\"><span data-lake-id=\"u80329ea1\" id=\"u80329ea1\">下载文件 放到public中</span><card type=\"inline\" name=\"file\" value=\"data:%7B%22src%22%3A%22https%3A%2F%2Fwww.yuque.com%2Fattachments%2Fyuque%2F0%2F2021%2Fzip%2F200222%2F1624419753892-257d1db6-9f0c-4e9f-850e-4676d4f5303b.zip%22%2C%22name%22%3A%22tinymce_5.8.1.zip%22%2C%22size%22%3A796412%2C%22type%22%3A%22application%2Fzip%22%2C%22ext%22%3A%22zip%22%2C%22status%22%3A%22done%22%2C%22taskId%22%3A%22ucda68060-bf4b-4d28-984b-072b8e45a96%22%2C%22taskType%22%3A%22upload%22%2C%22id%22%3A%22uff7bf008%22%2C%22downloadSrc%22%3A%22https%3A%2F%2Flark-assets-prod-aliyun.oss-cn-hangzhou.aliyuncs.com%2Fyuque%2F0%2F2021%2Fzip%2F200222%2F1624419753892-257d1db6-9f0c-4e9f-850e-4676d4f5303b.zip%3FOSSAccessKeyId%3DLTAI4GKnqTWmz2X8mzA1Sjbv%26Expires%3D1772828705%26Signature%3D4LDiZvyKoCnH1oxbDP3AN6Rfmds%253D%22%7D\"></card><span data-lake-id=\"ud7a53917\" id=\"ud7a53917\"> 并在index.html中引用 tinymce.min.js </span></li></ol><p data-lake-id=\"uca3adacf\" id=\"uca3adacf\" style=\"text-indent: 2em\"><span data-lake-id=\"u90552be3\" id=\"u90552be3\">中文化需要下载 </span><card type=\"inline\" name=\"file\" value=\"data:%7B%22src%22%3A%22https%3A%2F%2Fwww.yuque.com%2Fattachments%2Fyuque%2F0%2F2021%2Fjs%2F200222%2F1624420342999-f6ee3ad3-7d69-4ac5-9801-feb85ebc221f.js%22%2C%22name%22%3A%22zh_CN.js%22%2C%22size%22%3A19075%2C%22type%22%3A%22text%2Fjavascript%22%2C%22ext%22%3A%22js%22%2C%22status%22%3A%22done%22%2C%22taskId%22%3A%22uefa4b336-95e2-4024-8828-f85d39fe062%22%2C%22taskType%22%3A%22upload%22%2C%22id%22%3A%22u32411494%22%2C%22downloadSrc%22%3A%22https%3A%2F%2Flark-assets-prod-aliyun.oss-cn-hangzhou.aliyuncs.com%2Fyuque%2F0%2F2021%2Fjs%2F200222%2F1624420342999-f6ee3ad3-7d69-4ac5-9801-feb85ebc221f.js%3FOSSAccessKeyId%3DLTAI4GKnqTWmz2X8mzA1Sjbv%26Expires%3D1772828705%26Signature%3DIaoDzt8I1EYuKKY8zRSelJqbTRw%253D%22%7D\"></card></p><ol list=\"u5fef75e7\" start=\"2\"><li fid=\"u130289d0\" data-lake-id=\"ubc9ac604\" id=\"ubc9ac604\"><span data-lake-id=\"uc06c38c7\" id=\"uc06c38c7\">写成组件</span></li></ol><card type=\"inline\" name=\"codeblock\" value=\"data:%7B%22mode%22%3A%22vue%22%2C%22code%22%3A%22%3Ctemplate%3E%5Cn%20%20%3Cdiv%3E%5Cn%20%20%20%20%3Ctextarea%20%3Aid%3D%5C%22id%5C%22%20%3Avalue%3D%5C%22value%5C%22%3E%3C%2Ftextarea%3E%5Cn%20%20%3C%2Fdiv%3E%5Cn%3C%2Ftemplate%3E%5Cn%5Cn%3Cscript%3E%5Cnimport%20%7B%20mapActions%2C%20mapGetters%20%7D%20from%20'vuex'%5Cnimport%20'xx%2Fzh_CN.js'%20%2F%2F%20%E5%BC%95%E5%85%A5%E4%B8%AD%E6%96%87%5Cn%5Cnconst%20INIT%20%3D%200%5Cnexport%20default%20%7B%5Cn%20%20name%3A%20'TinymceEditor'%2C%5Cn%20%20props%3A%20%7B%5Cn%20%20%20%20value%3A%20%7B%5Cn%20%20%20%20%20%20type%3A%20String%2C%5Cn%20%20%20%20%20%20required%3A%20true%5Cn%20%20%20%20%7D%2C%5Cn%20%20%20%20setting%3A%20%7B%7D%5Cn%20%20%7D%2C%5Cn%20%20data()%20%7B%5Cn%20%20%20%20return%20%7B%5Cn%20%20%20%20%20%20status%3A%20INIT%2C%5Cn%20%20%20%20%20%20id%3A%20'editor-'%20%2B%20new%20Date().getMilliseconds()%2C%5Cn%20%20%20%20%20%20EDITOR%3A%20null%5Cn%20%20%20%20%7D%5Cn%20%20%7D%2C%5Cn%20%20computed%3A%20%7B%5Cn%20%20%20%20...mapGetters(%7B%5Cn%20%20%20%20%20%20uploadImg%3A%20'uploadImg'%2C%20%2F%2F%20%E8%87%AA%E5%AE%9A%E4%B9%89%E5%9B%BE%E7%89%87%E4%B8%8A%E4%BC%A0%5Cn%20%20%20%20%7D)%5Cn%20%20%7D%2C%5Cn%20%20mounted()%20%7B%5Cn%20%20%20%20const%20setting%20%3D%20%7B%5Cn%20%20%20%20%20%20selector%3A%20'%23'%20%2B%20this.id%2C%5Cn%20%20%20%20%20%20menubar%3A%20false%2C%5Cn%20%20%20%20%20%20language%3A%20'zh_CN'%2C%5Cn%20%20%20%20%20%20toolbar%3A%5Cn%20%20%20%20%20%20%20%20'formatselect%20bold%20italic%20underline%20strikethrough%20%7C%20fontselect%20fontsizeselect%20forecolor%20backcolor%20%7C%20alignleft%20aligncenter%20alignright%20alignjustify%20%7C%20bullist%20numlist%20%7C%20image%20table%20%7C%20link%20unlink%20%7C%20indent%20outdent%20%7C%20superscript%20subscript%20%7C%20removeformat%20%7C%20%20wordcount%20charmap%20%7C%20undo%20redo%20%7C%20fullscreen%20%7C%20'%2C%5Cn%20%20%20%20%20%20plugins%3A%20%5B%5Cn%20%20%20%20%20%20%20%20'link'%2C%5Cn%20%20%20%20%20%20%20%20'image'%2C%5Cn%20%20%20%20%20%20%20%20'imagetools'%2C%5Cn%20%20%20%20%20%20%20%20'table'%2C%5Cn%20%20%20%20%20%20%20%20'lists'%2C%5Cn%20%20%20%20%20%20%20%20'fullscreen'%2C%5Cn%20%20%20%20%20%20%20%20'quickbars'%2C%5Cn%20%20%20%20%20%20%20%20'charmap'%2C%5Cn%20%20%20%20%20%20%20%20'autolink'%2C%5Cn%20%20%20%20%20%20%20%20'wordcount'%5Cn%20%20%20%20%20%20%5D%2C%5Cn%20%20%20%20%20%20fontsize_formats%3A%20'12px%2014px%2016px%2018px%2024px%2036px%2048px%2056px%2072px'%2C%5Cn%20%20%20%20%20%20font_formats%3A%5Cn%20%20%20%20%20%20%20%20'%E5%BE%AE%E8%BD%AF%E9%9B%85%E9%BB%91%3DMicrosoft%20YaHei%2CHelvetica%20Neue%2CPingFang%20SC%2Csans-serif%3B%E8%8B%B9%E6%9E%9C%E8%8B%B9%E6%96%B9%3DPingFang%20SC%2CMicrosoft%20YaHei%2Csans-serif%3B%E5%AE%8B%E4%BD%93%3Dsimsun%2Cserif%3B%E4%BB%BF%E5%AE%8B%E4%BD%93%3DFangSong%2Cserif%3B%E9%BB%91%E4%BD%93%3DSimHei%2Csans-serif%3BArial%3Darial%2Chelvetica%2Csans-serif%3BArial%20Black%3Darial%20black%2Cavant%20garde%3BBook%20Antiqua%3Dbook%20antiqua%2Cpalatino%3B'%2C%20%2F%2F%E5%AD%97%E4%BD%93%E6%A0%B7%E5%BC%8F%5Cn%5Cn%20%20%20%20%20%20height%3A%20'500px'%2C%5Cn%20%20%20%20%20%20a11y_advanced_options%3A%20true%2C%5Cn%20%20%20%20%20%20branding%3A%20false%2C%20%2F%2F%E9%9A%90%E8%97%8F%E5%8F%B3%E4%B8%8B%E8%A7%92%E6%8A%80%E6%9C%AF%E6%94%AF%E6%8C%81%5Cn%20%20%20%20%20%20paste_retain_style_properties%3A%20'all'%2C%5Cn%20%20%20%20%20%20paste_data_images%3A%20true%2C%5Cn%20%20%20%20%20%20image_advtab%3A%20true%2C%20%2F%2F%E4%B8%BA%E5%9B%BE%E5%83%8F%E5%B1%9E%E6%80%A7%E7%BC%96%E8%BE%91%E7%AA%97%E5%8F%A3%E6%B7%BB%E5%8A%A0%E9%AB%98%E7%BA%A7%E5%B1%9E%E6%80%A7%EF%BC%8C%E5%8F%AF%E4%BB%A5%E8%87%AA%E5%AE%9A%E4%B9%89%E5%9B%BE%E7%89%87%E7%9A%84css%E6%A0%B7%E5%BC%8F%EF%BC%88%E5%86%85%E7%BD%AEstyle%EF%BC%89%E3%80%81%E8%BE%B9%E8%B7%9D%EF%BC%88margin%EF%BC%89%E5%92%8C%E8%BE%B9%E6%A1%86%EF%BC%88border%EF%BC%89%E3%80%82%5Cn%20%20%20%20%20%20image_description%3A%20false%2C%20%2F%2F%E6%98%BE%E7%A4%BA%E9%9A%90%E8%97%8F%E5%9B%BE%E7%89%87%E8%AF%B4%E6%98%8Einput%5Cn%20%20%20%20%20%20images_upload_handler%3A%20this.imgUpload%2C%5Cn%20%20%20%20%20%20imagetools_cors_hosts%3A%20%5B%5Cn%20%20%20%20%20%20%20%20'testimg.zuoyebang.cc'%2C%5Cn%20%20%20%20%20%20%20%20'img.zuoyebang.cc'%2C%5Cn%20%20%20%20%20%20%20%20'wiki.zuoyebang.cc'%5Cn%20%20%20%20%20%20%5D%2C%5Cn%20%20%20%20%20%20init_instance_callback%3A%20this.myCustomInitInstance%2C%5Cn%20%20%20%20%20%20quickbars_insert_toolbar%3A%20false%2C%5Cn%20%20%20%20%20%20quickbars_selection_toolbar%3A%20false%2C%5Cn%20%20%20%20%20%20placeholder%3A%20'%E8%AF%B7%E8%BE%93%E5%85%A5%E6%AD%A3%E6%96%87'%5Cn%20%20%20%20%7D%5Cn%20%20%20%20Object.assign(setting%2C%20this.setting)%5Cn%20%20%20%20tinymce.init(setting)%5Cn%20%20%7D%2C%5Cn%20%20beforeDestroy%3A%20function%20()%20%7B%5Cn%20%20%20%20tinymce.get(this.id).destroy()%5Cn%20%20%7D%2C%5Cn%20%20methods%3A%20%7B%5Cn%20%20%20%20...mapActions(%7B%5Cn%20%20%20%20%20%20uploading%3A%20'uploadImgAction'%5Cn%20%20%20%20%7D)%2C%5Cn%20%20%20%20myCustomInitInstance(editor)%20%7B%5Cn%20%20%20%20%20%20this.EDITOR%20%3D%20editor%5Cn%20%20%20%20%20%20editor.setContent(this.value)%5Cn%20%20%20%20%20%20editor.on('change%20input'%2C%20()%20%3D%3E%20%7B%5Cn%20%20%20%20%20%20%20%20var%20content%20%3D%20editor.getContent()%5Cn%20%20%20%20%20%20%20%20this.%24route.query.docId%5Cn%20%20%20%20%20%20%20%20%20%20%3F%20this.%24emit('input'%2C%20content)%5Cn%20%20%20%20%20%20%20%20%20%20%3A%20this.%24emit('change'%2C%20content)%5Cn%20%20%20%20%20%20%7D)%5Cn%20%20%20%20%7D%2C%5Cn%20%20%20%20async%20imgUpload(blobInfo%2C%20success%2C%20failure)%20%7B%5Cn%20%20%20%20%20%20%2F%2F%E6%96%87%E4%BB%B6%E4%B8%8A%E4%BC%A0%E7%9A%84formData%E4%BC%A0%E9%80%92%5Cn%20%20%20%20%20%20let%20formData%20%3D%20new%20FormData()%5Cn%20%20%20%20%20%20formData.append('file'%2C%20blobInfo.blob()%2C%20blobInfo.filename())%5Cn%20%20%20%20%20%20await%20this.uploading(formData)%5Cn%20%20%20%20%20%20this.uploadImg.picUrl%5Cn%20%20%20%20%20%20%20%20%3F%20success(this.uploadImg.picUrl)%5Cn%20%20%20%20%20%20%20%20%3A%20failure('%E4%B8%8A%E4%BC%A0%E5%A4%B1%E8%B4%A5')%5Cn%20%20%20%20%7D%5Cn%20%20%7D%5Cn%7D%5Cn%3C%2Fscript%3E%5Cn%22%2C%22autoWrap%22%3Atrue%2C%22theme%22%3A%22default%22%2C%22__spacing%22%3A%22both%22%2C%22heightLimit%22%3Atrue%2C%22id%22%3A%22LmQP5%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D\"></card><p data-lake-id=\"udf9d8a84\" id=\"udf9d8a84\"><span data-lake-id=\"u51567109\" id=\"u51567109\">3.父组件</span></p><card type=\"inline\" name=\"codeblock\" value=\"data:%7B%22mode%22%3A%22vue%22%2C%22code%22%3A%22%3Cel-form-item%20prop%3D%5C%22content%5C%22%3E%5Cn%5Ct%5Ct%3Ctiny-editor-page%5Cn%5Ct%5Ct%5Ct%5Ctclass%3D%5C%22editor%5C%22%5Cn%20%20%20%20%20%20%20%20%3Avalue%3D%5C%22form.content%5C%22%5Cn%20%20%20%20%20%20%20%20%40change%3D%5C%22contentUe%5C%22%5Cn%20%20%20%20%3E%3C%2Ftiny-editor-page%3E%5Cn%3C%2Fel-form-item%3E%5Cn%5Cn%3Cscript%3E%5Cn%20%20%5Cn...%5Cn%5Cnmethods%3A%7B%5Cn%5Ct%5CtcontentUe(value)%20%7B%5Cn%20%20%20%20%20%20this.form.content%20%3D%20value%20%2F%2F%E5%AF%8C%E6%96%87%E6%9C%AC%E4%B8%AD%E7%9A%84%E5%86%85%E5%AE%B9%5Cn%20%20%20%20%7D%2C%5Cn%7D%5Cn...%5Cn%3C%2Fscript%3E%22%2C%22autoWrap%22%3Atrue%2C%22theme%22%3A%22default%22%2C%22__spacing%22%3A%22both%22%2C%22heightLimit%22%3Atrue%2C%22id%22%3A%22vGbYx%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%7D\"></card><p data-lake-id=\"u5414d40d\" id=\"u5414d40d\"><span data-lake-id=\"uc080e45b\" id=\"uc080e45b\" class=\"lake-fontsize-12\" style=\"color: #ce9178; background-color: #1e1e1e\">​</span><br></p><p data-lake-id=\"u02006b3b\" id=\"u02006b3b\"><br></p>","body_draft":"<!doctype html><div class=\"lake-content\" typography=\"classic\"><pre data-language=\"html\" id=\"PNu84\" class=\"ne-codeblock\">npm i tinymce</pre><p id=\"ud00245a3\" class=\"ne-p\"><span class=\"ne-text\">简单粗暴的方式：</span></p><ol class=\"ne-ol\"><li id=\"ua813a46a\"><span class=\"ne-text\">下载文件 放到public中</span><a href=\"https://www.yuque.com/attachments/yuque/0/2021/zip/200222/1624419753892-257d1db6-9f0c-4e9f-850e-4676d4f5303b.zip\" id=\"uff7bf008\" class=\"ne-card-file\">📎tinymce_5.8.1.zip</a><span class=\"ne-text\"> 并在index.html中引用 tinymce.min.js </span></li></ol><p id=\"uca3adacf\" class=\"ne-p\" style=\"text-indent: 2em\"><span class=\"ne-text\">中文化需要下载 </span><a href=\"https://www.yuque.com/attachments/yuque/0/2021/js/200222/1624420342999-f6ee3ad3-7d69-4ac5-9801-feb85ebc221f.js\" id=\"u32411494\" class=\"ne-card-file\">📎zh_CN.js</a></p><ol start=\"2\" class=\"ne-ol\"><li id=\"ubc9ac604\"><span class=\"ne-text\">写成组件</span></li></ol><pre data-language=\"vue\" id=\"LmQP5\" class=\"ne-codeblock\">&lt;template&gt;\n  &lt;div&gt;\n    &lt;textarea :id=&quot;id&quot; :value=&quot;value&quot;&gt;&lt;/textarea&gt;\n  &lt;/div&gt;\n&lt;/template&gt;\n\n&lt;script&gt;\nimport { mapActions, mapGetters } from 'vuex'\nimport 'xx/zh_CN.js' // 引入中文\n\nconst INIT = 0\nexport default {\n  name: 'TinymceEditor',\n  props: {\n    value: {\n      type: String,\n      required: true\n    },\n    setting: {}\n  },\n  data() {\n    return {\n      status: INIT,\n      id: 'editor-' + new Date().getMilliseconds(),\n      EDITOR: null\n    }\n  },\n  computed: {\n    ...mapGetters({\n      uploadImg: 'uploadImg', // 自定义图片上传\n    })\n  },\n  mounted() {\n    const setting = {\n      selector: '#' + this.id,\n      menubar: false,\n      language: 'zh_CN',\n      toolbar:\n        'formatselect bold italic underline strikethrough | fontselect fontsizeselect forecolor backcolor | alignleft aligncenter alignright alignjustify | bullist numlist | image table | link unlink | indent outdent | superscript subscript | removeformat |  wordcount charmap | undo redo | fullscreen | ',\n      plugins: [\n        'link',\n        'image',\n        'imagetools',\n        'table',\n        'lists',\n        'fullscreen',\n        'quickbars',\n        'charmap',\n        'autolink',\n        'wordcount'\n      ],\n      fontsize_formats: '12px 14px 16px 18px 24px 36px 48px 56px 72px',\n      font_formats:\n        '微软雅黑=Microsoft YaHei,Helvetica Neue,PingFang SC,sans-serif;苹果苹方=PingFang SC,Microsoft YaHei,sans-serif;宋体=simsun,serif;仿宋体=FangSong,serif;黑体=SimHei,sans-serif;Arial=arial,helvetica,sans-serif;Arial Black=arial black,avant garde;Book Antiqua=book antiqua,palatino;', //字体样式\n\n      height: '500px',\n      a11y_advanced_options: true,\n      branding: false, //隐藏右下角技术支持\n      paste_retain_style_properties: 'all',\n      paste_data_images: true,\n      image_advtab: true, //为图像属性编辑窗口添加高级属性，可以自定义图片的css样式（内置style）、边距（margin）和边框（border）。\n      image_description: false, //显示隐藏图片说明input\n      images_upload_handler: this.imgUpload,\n      imagetools_cors_hosts: [\n        'testimg.zuoyebang.cc',\n        'img.zuoyebang.cc',\n        'wiki.zuoyebang.cc'\n      ],\n      init_instance_callback: this.myCustomInitInstance,\n      quickbars_insert_toolbar: false,\n      quickbars_selection_toolbar: false,\n      placeholder: '请输入正文'\n    }\n    Object.assign(setting, this.setting)\n    tinymce.init(setting)\n  },\n  beforeDestroy: function () {\n    tinymce.get(this.id).destroy()\n  },\n  methods: {\n    ...mapActions({\n      uploading: 'uploadImgAction'\n    }),\n    myCustomInitInstance(editor) {\n      this.EDITOR = editor\n      editor.setContent(this.value)\n      editor.on('change input', () =&gt; {\n        var content = editor.getContent()\n        this.$route.query.docId\n          ? this.$emit('input', content)\n          : this.$emit('change', content)\n      })\n    },\n    async imgUpload(blobInfo, success, failure) {\n      //文件上传的formData传递\n      let formData = new FormData()\n      formData.append('file', blobInfo.blob(), blobInfo.filename())\n      await this.uploading(formData)\n      this.uploadImg.picUrl\n        ? success(this.uploadImg.picUrl)\n        : failure('上传失败')\n    }\n  }\n}\n&lt;/script&gt;\n</pre><p id=\"udf9d8a84\" class=\"ne-p\"><span class=\"ne-text\">3.父组件</span></p><pre data-language=\"vue\" id=\"vGbYx\" class=\"ne-codeblock\">&lt;el-form-item prop=&quot;content&quot;&gt;\n\t\t&lt;tiny-editor-page\n\t\t\t\tclass=&quot;editor&quot;\n        :value=&quot;form.content&quot;\n        @change=&quot;contentUe&quot;\n    &gt;&lt;/tiny-editor-page&gt;\n&lt;/el-form