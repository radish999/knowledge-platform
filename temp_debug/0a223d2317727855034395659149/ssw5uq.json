3A12.76034999999996%2C%22text%22%3A%22%E8%AE%BF%E6%B2%B3%E7%94%A8%E6%88%B7%22%7D%2C%7B%22x%22%3A179.80334%2C%22y%22%3A367.02026%2C%22width%22%3A133.42270000000002%2C%22height%22%3A13.204340000000002%2C%22text%22%3A%229.%E8%BF%94%E5%9B%9E%E5%9F%9F%E5%90%8D%E5%AF%B9%E5%BA%94%E7%9A%84%E5%B7%A5P%E5%9C%B0%E5%9D%80%22%7D%2C%7B%22x%22%3A294.63785%2C%22y%22%3A493.25247%2C%22width%22%3A71.24457000000001%2C%22height%22%3A10.549069999999972%2C%22text%22%3A%22HaueServer%22%7D%5D%2C%22style%22%3A%22none%22%2C%22search%22%3A%22ILD%20Server%207.%E8%BF%94%E5%9B%9ENameServer%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%9C%B0%E5%9D%80%206.%E5%90%91%3ATLD%E5%9F%9F%E5%90%8D%E8%A7%A3%E6%9E%90%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%8F%91%E8%B5%B7%E8%AF%B7%E6%B1%82%20.%E8%AF%B7%E6%A0%B9%E5%9F%9F%E5%90%8D%E5%8F%91%E8%B5%B7%E8%A7%A3%E6%9E%90%E8%AF%B7%E6%B1%82%205.%E8%BF%94%E5%9B%9E.LD%E5%9F%9F%E5%90%8D%E8%A7%A3%E6%9E%90%E6%9C%8D%E5%8A%A1%E5%99%A8%E5%9C%B0%E5%9D%80%203%2C%E7%BF%BB%E6%88%B7%E5%8F%91%E6%80%92%E8%AF%B7%E6%B1%82%20LocalD's%20RootDis%20Server%20Server%2010.%E8%BF%94%E5%8C%85%E5%9F%9F%E5%90%8D%E5%AF%B9%E5%BA%94%E7%9A%84%E6%94%BB%E5%9C%B0%E5%9D%80%208.%E6%9F%A5%E8%AF%A2%E8%AF%B7%E6%B1%82%E7%9A%84%E5%9F%9F%E5%90%8D%E5%AF%B9%E5%BA%94%E7%9A%84%E5%B7%A5P%E5%9C%B0%E5%9D%80%20%E8%AE%BF%E6%B2%B3%E7%94%A8%E6%88%B7%209.%E8%BF%94%E5%9B%9E%E5%9F%9F%E5%90%8D%E5%AF%B9%E5%BA%94%E7%9A%84%E5%B7%A5P%E5%9C%B0%E5%9D%80%20HaueServer%22%2C%22margin%22%3A%7B%22top%22%3Atrue%2C%22bottom%22%3Atrue%7D%2C%22width%22%3A555%2C%22height%22%3A413%7D\"></card></p><p data-lake-id=\"3fea76965af7b6dac6c772bed3709d9f\">当在浏览器中输入一个URL后：</p><ol data-lake-id=\"f9f09436fb38ef32ad964498be10d2f3\" start=\"1\"><li data-lake-id=\"78e273e5e59e73c40913976c09b0bf49\">浏览器先检查自身缓存中有没有被解析过的这个域名对应的IP地址，如果有，解析结束；同时域名被缓存的实际也可以通过TTL属性设置</li><li data-lake-id=\"c5c957a2068d64445fd6ae568dc77639\">如果浏览器缓存中没有（专业点叫还没命中）浏览器会检查操作系统缓存中有没有对应的已解析过的结果。而操作系统也有一个域名解析过程</li><li data-lake-id=\"2b10f7e62c9db48a37b4c49a0158ef39\">如果至此还没命中域名，才会真正的请求本地域名服务器（LDNS）来解析这个域名，这台服务器一般在请求设备所在城市的某个角落，距离请求设备不会很远，并且这台服务器性能很好，一般都会缓存域名解析结果，大约80%的域名解析到这里就完成了</li><li data-lake-id=\"5ad0ac190acfa05ae621d61e322624b7\">如果LDNS仍然没有命中，就直接跳到<span>根域名服务器 （</span>Root Server）请求解析</li><li data-lake-id=\"047155f999cbdf58ee4145b65255de51\">根域名服务器（<span>Root Server</span>）返回给LDNS一个所查询域的主域名服务器（gTLD Server 国际顶级域名服务器，如： .com .cn .org等）地址</li><li data-lake-id=\"abf8f73d5639918e279d30cdde6925a6\">此时LDNS再发送请求给上一步返回的gTLD</li><li data-lake-id=\"a9620f90609070f7a25bac89b5b0de64\">接受请求的gTLD查找并返回这个域名对应的 Name Server的地址，这个name server就是网站注册的域名服务器</li><li data-lake-id=\"2181c1e2a8532d1c69ef8df761b06003\">name server 根据映射关系表找到目标IP，返回给LDNS</li><li data-lake-id=\"a615f7b6ff0ee868302e5ab106ea3a60\">LDNS缓存这个域名和对应的ip</li><li data-lake-id=\"ac830799a3d32712d59f424ae80d6ec6\">LDNS把解析的结果返回给用户，用户根据TTL值缓存到本地系统缓存中，域名解析过程至此结束；<cursor /></li></ol><p data-lake-id=\"b8e0a56f411a9bf8f09b30f8bc71054c\"><br /></p>","body_draft":"<!doctype html><div class=\"lake-content-editor-core lake-engine lake-typography-classic\" data-lake-element=\"root\" data-selection-undefined=\"%7B%22path%22%3A%5B%5B2%2C9%2C0%2C46%5D%2C%5B2%2C9%2C0%2C46%5D%5D%2C%22active%22%3Atrue%7D\"><p data-lake-id=\"a20d224c568e48b9d67847a2c66a8c01_p_0\" style=\"font-size: 14px; color: rgb(38, 38, 38); line-height: 1.74; letter-spacing: 0.05em; outline-style: none; overflow-wrap: break-word; margin: 0px;\"><span data-card-type=\"inline\" data-lake-card=\"image\" class=\"lake-card-margin-top lake-card-margin-bottom\"><img data-role=\"image\" src=\"https://cdn.nlark.com/yuque/0/2021/png/200222/1613803206620-1f208a1b-9fb4-4e2f-86bd-caba643694b7.png\" data-raw-src=\"\" class=\"image lake-drag-image\" alt=\"image.png\" title=\"image.png\" data-height=\"413px\" style=\"visibility: visible; width: 555px;\"></span></p><p data-lake-id=\"3fea76965af7b6dac6c772bed3709d9f\" style=\"font-size: 14px; color: rgb(38, 38, 38); line-height: 1.74; letter-spacing: 0.05em; outline-style: none; overflow-wrap: break-word; margin: 0px;\">当在浏览器中输入一个URL后：</p><ol data-lake-id=\"f9f09436fb38ef32ad964498be10d2f3\" start=\"1\" lake-indent=\"0\" style=\"list-style-type: decimal; margin: 0px; padding-left: 23px; font-size: 14px; color: rgb(38, 38, 38); line-height: 1.74; letter-spacing: 0.05em; outline-style: none; overflow-wrap: break-word;\"><li data-lake-id=\"78e273e5e59e73c40913976c09b0bf49\">浏览器先检查自身缓存中有没有被解析过的这个域名对应的IP地址，如果有，解析结束；同时域名被缓存的实际也可以通过TTL属性设置</li><li data-lake-id=\"c5c957a2068d64445fd6ae568dc77639\">如果浏览器缓存中没有（专业点叫还没命中）浏览器会检查操作系统缓存中有没有对应的已解析过的结果。而操作系统也有一个域名解析过程</li><li data-lake-id=\"2b10f7e62c9db48a37b4c49a0158ef39\">如果至此还没命中域名，才会真正的请求本地域名服务器（LDNS）来解析这个域名，这台服务器一般在请求设备所在城市的某个角落，距离请求设备不会很远，并且这台服务器性能很好，一般都会缓存域名解析结果，大约80%的域名解析到这里就完成了</li><li data-lake-id=\"5ad0ac190acfa05ae621d61e322624b7\">如果LDNS仍然没有命中，就直接跳到<span>根域名服务器 （</span>Root Server）请求解析</li><li data-lake-id=\"047155f999cbdf58ee4145b65255de51\">根域名服务器（<span>Root Server</span>）返回给LDNS一个所查询域的主域名服务器（gTLD Server 国际顶级域名服务器，如： .com .cn .org等）地址</li><li data-lake-id=\"abf8f73d5639918e279d30cdde6925a6\">此时LDNS再发送请求给上一步返回的gTLD</li><li data-lake-id=\"a9620f90609070f7a25bac89b5b0de64\">接受请求的gTLD查找并返回这个域名对应的 Name Server的地址，这个name server就是网站注册的域名服务器</li><li data-lake-id=\"2181c1e2a8532d1c69ef8df761b06003\">name server 根据映射关系表找到目标IP，返回给LDNS</li><li data-lake-id=\"a615f7b6ff0ee868302e5ab106ea3a60\">LDNS缓存这个域名和对应的ip</li><li data-lake-id=\"ac830799a3d32712d59f424ae80d6ec6\">LDNS把解析的结果返回给用户，用户根据TTL值缓存到本地系统缓存中，域名解析过程至此结束；</li></ol><p data-lake-id=\"b8e0a56f411a9bf8f09b30f8bc71054c\" style=\"font-size: 14px; color: rgb(38, 38, 38); line-height: 1.74; letter-spacing: 0.05em; outline-style: none; overflow-wrap: break-word; margin: 0px;\"><br></p></div>","body_draft_asl":"<!doctype lake><meta name=\"doc-version\" content=\"1\" /><meta name=\"viewport\" content=\"fixed\" /><meta name=\"typography\" content=\"classic\" /><p data-lake-id=\"a20d224c568e48b9d67847a2c66a8c01_p_0\"><card type=\"inline\" name=\"image\" value=\"data:%7B%22src%22%3A%22https%3A%2F%2Fcdn.nlark.com%2Fyuque%2F0